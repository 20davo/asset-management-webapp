# Example environment variables for running the API outside local appsettings.Development.json.
# This file is documentation only. The app will not load it automatically unless Docker Compose
# or your shell exports these variables into the process environment.

# ASP.NET runtime environment
ASPNETCORE_ENVIRONMENT=Development

# Database connection string
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=asset_management;Username=postgres;Password=postgres

# JWT settings
Jwt__Key=replace-with-a-long-random-secret-key
Jwt__Issuer=AssetManagement.Api
Jwt__Audience=AssetManagement.Client

# CORS origins
# Arrays use numeric indexes in .NET environment variable mapping.
Cors__AllowedOrigins__0=http://localhost:5173
Cors__AllowedOrigins__1=https://localhost:5173
Cors__AllowedOrigins__2=http://localhost:3000
Cors__AllowedOrigins__3=https://localhost:3000
