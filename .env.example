# Docker Compose reads variables from a root .env file and substitutes them into compose.yaml.
# This example documents the values used by the local development stack.

# Host ports exposed on your machine
FRONTEND_PORT=5173
API_PORT=5071
POSTGRES_PORT=5433

# Frontend runtime configuration
FRONTEND_API_BASE_URL=http://localhost:5071/api
VITE_REGISTRATION_ENABLED=true

# PostgreSQL container configuration
POSTGRES_IMAGE_TAG=16
POSTGRES_DB=asset_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# API secrets and app configuration
ASPNETCORE_ENVIRONMENT=Development
JWT_KEY=change-this-to-a-real-random-secret
JWT_ISSUER=AssetManagement.Api
JWT_AUDIENCE=AssetManagement.Client
REGISTRATION_ENABLED=true
AUTH_RATE_LIMIT_ENABLED=false
AUTH_RATE_LIMIT_PERMIT_LIMIT=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# Optional local bootstrap admin. Keep this disabled outside local development.
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_NAME=Admin
BOOTSTRAP_ADMIN_EMAIL=admin@assetmanagement.local
BOOTSTRAP_ADMIN_PASSWORD=Admin123!

# CORS origins allowed by the API
CORS_ALLOWED_ORIGIN_0=http://localhost:5173
CORS_ALLOWED_ORIGIN_1=https://localhost:5173
